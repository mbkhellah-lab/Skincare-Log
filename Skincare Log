* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

body {
  background: var(--black);
  color: var(--text);
  font-family: 'Cormorant Garamond', Georgia, serif;
  min-height: 100vh;
  min-height: -webkit-fill-available;
  padding-bottom: env(safe-area-inset-bottom, 20px);
  padding-bottom: calc(env(safe-area-inset-bottom, 20px) + 60px);
  overflow-x: hidden;
}

/* Header */
.header {
  background: linear-gradient(180deg, #0f0a1a 0%, #080808 100%);
  border-bottom: 1px solid rgba(155,114,207,0.15);
  padding: calc(env(safe-area-inset-top, 20px) + 24px) 24px 20px;
  text-align: center;
}
.header-eyebrow {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 9px;
  letter-spacing: 6px;
  color: var(--purple);
  text-transform: uppercase;
  margin-bottom: 6px;
}
.header-title {
  font-size: 30px;
  font-weight: 300;
  letter-spacing: 3px;
  color: var(--text);
}
.header-sub {
  font-style: italic;
  color: rgba(201,169,110,0.5);
  font-size: 13px;
  margin-top: 4px;
}

/* Stats */
.stats {
  display: flex;
  gap: 8px;
  padding: 18px 16px 0;
  animation: fadeUp 0.4s ease;
}
.stat-card {
  flex: 1;
  background: #0f0f0f;
  border-radius: 14px;
  padding: 14px 6px;
  text-align: center;
}
.stat-val {
  font-size: 26px;
  font-weight: 600;
  line-height: 1;
}
.stat-label {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 8px;
  letter-spacing: 1.5px;
  color: var(--muted);
  text-transform: uppercase;
  margin-top: 5px;
}

/* Section label */
.section-label {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 9px;
  letter-spacing: 4px;
  color: var(--muted);
  text-transform: uppercase;
  margin-bottom: 12px;
}

/* Calendar */
.calendar-wrap { padding: 20px 16px 0; }
.cal-grid {
  display: grid;
  grid-template-columns: repeat(10, 1fr);
  gap: 5px;
}
.cal-dot {
  aspect-ratio: 1;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  cursor: pointer;
  transition: transform 0.15s ease;
  border: 2px solid transparent;
  user-select: none;
}
.cal-dot:active { transform: scale(0.9); }
.cal-dot.today { border-color: rgba(155,114,207,0.5); }
.cal-dot.selected { border-color: #fff !important; transform: scale(1.1); }

/* Legend */
.legend {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 12px;
}
.legend-item {
  display: flex;
  align-items: center;
  gap: 5px;
}
.legend-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
}
.legend-label {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 8px;
  letter-spacing: 1px;
  color: var(--muted);
  text-transform: uppercase;
}

/* Log card */
.log-card {
  margin: 16px;
  background: var(--card);
  border: 1px solid rgba(155,114,207,0.15);
  border-radius: 18px;
  padding: 20px;
  animation: fadeUp 0.5s ease;
}
.log-date {
  font-size: 20px;
  font-weight: 300;
  margin-bottom: 4px;
}
.log-today-badge {
  font-size: 11px;
  color: var(--purple);
  font-style: italic;
  margin-left: 6px;
}
.current-log {
  border-radius: 10px;
  padding: 10px 14px;
  margin: 12px 0;
  font-family: 'Josefin Sans', sans-serif;
  font-size: 11px;
  letter-spacing: 1px;
}
.btn-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-top: 12px;
}
.log-btn {
  background: #111;
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 14px;
  padding: 16px 10px;
  color: #777;
  font-family: 'Josefin Sans', sans-serif;
  font-size: 10px;
  letter-spacing: 1px;
  text-transform: uppercase;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 7px;
  cursor: pointer;
  transition: all 0.2s ease;
  -webkit-appearance: none;
}
.log-btn:active { transform: scale(0.96); }
.log-btn .btn-emoji { font-size: 22px; }
.log-btn.active { color: var(--btn-color); background: var(--btn-bg); border-color: var(--btn-color); }
.back-btn {
  width: 100%;
  margin-top: 12px;
  background: transparent;
  border: 1px solid #2a2a2a;
  border-radius: 12px;
  padding: 11px;
  color: var(--muted);
  font-family: 'Josefin Sans', sans-serif;
  font-size: 9px;
  letter-spacing: 2px;
  text-transform: uppercase;
  cursor: pointer;
  -webkit-appearance: none;
}

/* Reminder card */
.reminder-card {
  margin: 0 16px 16px;
  background: var(--card);
  border: 1px solid rgba(201,169,110,0.15);
  border-radius: 18px;
  padding: 18px 20px;
}
.reminder-steps {
  font-size: 13px;
  font-style: italic;
  line-height: 1.9;
}
.reminder-steps span {
  display: block;
  padding: 1px 0;
}

/* Toast */
.toast {
  position: fixed;
  bottom: calc(env(safe-area-inset-bottom, 20px) + 20px);
  left: 50%;
  transform: translateX(-50%);
  background: #1a0d2e;
  border: 1px solid rgba(155,114,207,0.4);
  border-radius: 50px;
  padding: 12px 24px;
  font-family: 'Josefin Sans', sans-serif;
  font-size: 11px;
  color: var(--purple);
  letter-spacing: 1px;
  white-space: nowrap;
  z-index: 999;
  animation: slideUp 0.3s ease;
  pointer-events: none;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes slideUp {
  from { opacity: 0; transform: translateX(-50%) translateY(15px); }
  to { opacity: 1; transform: translateX(-50%) translateY(0); }
}
