<body>

  <div class="header">
    <div class="header-eyebrow">Skin Journal</div>
    <h1 class="header-title">Moe's Routine</h1>
    <div class="header-sub">Luxury with restraint.</div>
  </div>

  <div class="stats" id="stats"></div>
  <div class="calendar-wrap">
    <div class="section-label">Last 30 Days</div>
    <div class="cal-grid" id="calGrid"></div>
    <div class="legend" id="legend"></div>
  </div>
  <div class="log-card" id="logCard"></div>
  <div class="reminder-card" id="reminderCard"></div>
  <div class="toast" id="toast" style="display:none"></div>

  <script>
    const STORAGE_KEY = 'moe-skin-log-v1';
    const TYPES = {
      tret:    { label: 'Tretinoin',        emoji: '✨', color: '#9b72cf', bg: 'rgba(155,114,207,0.15)' },
      pads:    { label: 'Revive RX Pads',   emoji: '🌿', color: '#72cfaa', bg: 'rgba(114,207,170,0.15)' },
      plain:   { label: 'Plain Off Night',  emoji: '🌙', color: '#C9A96E', bg: 'rgba(201,169,110,0.15)' },
      skipped: { label: 'Skipped',          emoji: '💤', color: '#444',    bg: 'rgba(68,68,68,0.15)' },
    };

    const ROUTINES = {
      tret:    ['Cleanser', 'Oatmeal Toner (wait 15 min)', 'Tretinoin', 'Vanicream'],
      pads:    ['Cleanser', 'Revive RX Pad', 'Skinnutritions Serum', 'Azelaic Acid', 'Snail Mucin'],
      plain:   ['Cleanser', 'Skinnutritions Serum', 'Azelaic Acid', 'Snail Mucin'],
      morning: ['Cleanser', 'Skinnutritions Serum', 'Azelaic Acid', 'Snail Mucin', 'SPF'],
      skipped: [],
    };

    let log = {};
    let selectedDay = null;

    function getTodayStr() {
      const d = new Date();
      return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
    }

    function getLast30() {
      const days = [];
      for (let i = 29; i >= 0; i--) {
        const d = new Date(); d.setDate(d.getDate() - i);
        days.push(`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`);
      }
      return days;
    }

    function formatDate(str) {
      const [y,m,d] = str.split('-').map(Number);
      return new Date(y,m-1,d).toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'});
    }

    function loadLog() {
      try { log = JSON.parse(localStorage.getItem(STORAGE_KEY)) || {}; } catch { log = {}; }
    }

    function saveLog() {
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(log)); } catch {}
    }

    function getStats() {
      const vals = Object.values(log);
      const days = getLast30();
      let streak = 0;
      for (let i = days.length - 1; i >= 0; i--) {
        if (log[days[i]] && log[days[i]] !== 'skipped') streak++;
        else break;
      }
      return {
        tret: vals.filter(v => v === 'tret').length,
        pads: vals.filter(v => v === 'pads').length,
        streak,
      };
    }

    function showToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.style.display = 'block';
      clearTimeout(t._timer);
      t._timer = setTimeout(() => { t.style.display = 'none'; }, 2500);
    }

    function logNight(type) {
      const target = selectedDay || getTodayStr();
      log[target] = type;
      saveLog();
      selectedDay = null;
      showToast(`${TYPES[type].emoji} ${TYPES[type].label} logged`);
      render();
    }

    function render() {
      const today = getTodayStr();
      const days = getLast30();
      const stats = getStats();
      const active = selectedDay || today;

      // Stats
      document.getElementById('stats').innerHTML = [
        { label: 'Tret Nights', val: stats.tret, color: '#9b72cf' },
        { label: 'Pad Nights',  val: stats.pads,  color: '#72cfaa' },
        { label: 'Day Streak',  val: stats.streak + 'd', color: '#C9A96E' },
      ].map(s => `
        <div class="stat-card" style="border:1px solid ${s.color}22">
          <div class="stat-val" style="color:${s.color}">${s.val}</div>
          <div class="stat-label">${s.label}</div>
        </div>
      `).join('');

      // Calendar
      document.getElementById('calGrid').innerHTML = days.map(day => {
        const type = log[day];
        const isToday = day === today;
        const isSel = day === selectedDay;
        const bg = type ? TYPES[type].bg : (isToday ? 'rgba(155,114,207,0.08)' : '#111');
        const border = isSel ? '#fff' : (isToday ? 'rgba(155,114,207,0.4)' : (type ? TYPES[type].color + '55' : 'transparent'));
        const inner = type ? TYPES[type].emoji : (isToday ? '·' : '');
        return `<div class="cal-dot${isToday?' today':''}${isSel?' selected':''}" 
          style="background:${bg};border-color:${border}" 
          onclick="selectDay('${day}')" title="${formatDate(day)}">${inner}</div>`;
      }).join('');

      // Legend
      document.getElementById('legend').innerHTML = Object.entries(TYPES).map(([k,v]) =>
        `<div class="legend-item">
          <div class="legend-dot" style="background:${v.color}"></div>
          <div class="legend-label">${v.label}</div>
        </div>`
      ).join('');

      // Log card
      const currentType = log[active];
      const currentBadge = currentType ? `
        <div class="current-log" style="background:${TYPES[currentType].bg};border:1px solid ${TYPES[currentType].color}44;color:${TYPES[currentType].color}">
          Currently: ${TYPES[currentType].emoji} ${TYPES[currentType].label}
        </div>` : '';

      const btns = Object.entries(TYPES).map(([k,v]) => {
        const isActive = currentType === k;
        return `<button class="log-btn${isActive?' active':''}" 
          style="--btn-color:${v.color};--btn-bg:${v.bg}"
          onclick="logNight('${k}')">
          <span class="btn-emoji">${v.emoji}</span>${v.label}
        </button>`;
      }).join('');

      const backBtn = selectedDay ? `<button class="back-btn" onclick="selectDay(null)">↩ Back to Today</button>` : '';

      document.getElementById('logCard').innerHTML = `
        <div class="section-label" style="color:var(--purple)">Logging for</div>
        <div class="log-date">${formatDate(active)}${active === today ? '<span class="log-today-badge">— today</span>' : ''}</div>
        ${currentBadge}
        <div class="btn-grid">${btns}</div>
        ${backBtn}
      `;

      // Reminder
      const todayType = log[today];
      const steps = ROUTINES[todayType] || ROUTINES.plain;
      const stepColors = { tret: '#9b72cf', pads: '#72cfaa', plain: '#C9A96E', skipped: '#444' };
      const color = stepColors[todayType] || '#C9A96E';
      const stepsHtml = todayType === 'skipped' ? '<span style="color:#444">Rest night 💤</span>' :
        steps.map((s,i) => `<span style="color:${color}88">${i+1}. <span style="color:${color}">${s}</span></span>`).join('');

      document.getElementById('reminderCard').innerHTML = `
        <div class="section-label" style="color:var(--gold)">Tonight's Steps</div>
        <div class="reminder-steps">${stepsHtml || '<span style="color:#555;font-style:italic">Log tonight to see your routine</span>'}</div>
      `;
    }

    function selectDay(day) {
      selectedDay = (selectedDay === day || day === null) ? null : day;
      render();
    }

    loadLog();
    render();
  </script>

</body>
